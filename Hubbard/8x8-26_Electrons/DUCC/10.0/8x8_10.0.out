+        try:
+            result = solve_miniccpy(
+                data,
+                method=args.cc_method,
+                maxit=args.cc_maxit,
+                convergence=args.cc_convergence,
+                level_shift=args.cc_level_shift,
+                diis_size=args.cc_diis_size,
+                miniccpy_path=args.miniccpy_path,
