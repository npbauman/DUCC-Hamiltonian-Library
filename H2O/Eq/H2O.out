+
+template<typename T>
+std::vector<Tensor<T>>& ccsd_residuals(Scheduler& sch, ChemEnv& chem_env,
+                                       const TiledIndexSpace& MO, const TensorMap<T>& f,
+                                       const TensorMap<T>& eri, TensorMap<T>& t1,
+                                       TensorMap<T>& t2, Tensor<T>& energy, TensorMap<T>& r1,
+                                       TensorMap<T>& r2, const std::vector<Tensor<T>>& d_t,
+                                       std::vector<Tensor<T>>& d_r) {
+  const auto& d_t1 = d_t.at(0);
+  const auto& d_t2 = d_t.at(1);
+  auto&       d_r1 = d_r.at(0);
+  auto&       d_r2 = d_r.at(1);
+
+  const int otiles  = MO("occ").num_tiles();
+  const int vtiles  = MO("virt").num_tiles();
+  const int oatiles = MO("occ_alpha").num_tiles();
+  const int vatiles = MO("virt_alpha").num_tiles();
+
+  const TiledIndexSpace Oa = {MO("occ"), range(oatiles)};
+  const TiledIndexSpace Va = {MO("virt"), range(vatiles)};
+  const TiledIndexSpace Ob = {MO("occ"), range(oatiles, otiles)};
+  const TiledIndexSpace Vb = {MO("virt"), range(vatiles, vtiles)};
+
+  TiledIndexLabel aa, ba;
+  TiledIndexLabel ia, ja;
+  TiledIndexLabel ab, bb;
+  TiledIndexLabel ib, jb;
+
+  std::tie(aa, ba) = Va.labels<2>("all");
+  std::tie(ab, bb) = Vb.labels<2>("all");
+  std::tie(ia, ja) = Oa.labels<2>("all");
+  std::tie(ib, jb) = Ob.labels<2>("all");
+
+  // clang-format off
+  sch
+    (   t1.at("aa")(aa,ia)          = d_t1(aa,ia))
+    (   t1.at("bb")(ab,ib)          = d_t1(ab,ib))
+    (   t2.at("aaaa")(aa,ba,ia,ja)  = d_t2(aa,ba,ia,ja))
+    (   t2.at("abab")(aa,bb,ia,jb)  = d_t2(aa,bb,ia,jb))
+    (   t2.at("bbbb")(ab,bb,ib,jb)  = d_t2(ab,bb,ib,jb))
+    .execute();
+  // clang-format on
+
+  ccsd_os::residuals<T>(sch, chem_env, MO, f, eri, t1, t2, energy, r1, r2);
+
+  // clang-format off
+  sch
+    (   d_r1(aa,ia)          = r1.at("aa")(aa,ia))
+    (   d_r1(ab,ib)          = r1.at("bb")(ab,ib))
+    (   d_r2(aa,ba,ia,ja)    = r2.at("aaaa")(aa,ba,ia,ja))
+    (   d_r2(aa,bb,ia,jb)    = r2.at("abab")(aa,bb,ia,jb))
+    (   d_r2(ab,bb,ib,jb)    = r2.at("bbbb")(ab,bb,ib,jb))
+    .execute();
+  // clang-format on
+
+  return d_r;
+}
+
+
+template<typename T>
+double NK_norm(const std::vector<Tensor<T>>& v) {
+  double norm_tensor  = 0.0;
+  double norm_squared = 0.0;
+
+  for(const auto& tensor: v) {
+    norm_tensor = norm(tensor);
+    norm_squared += norm_tensor * norm_tensor;
+  }
+  
+  return std::sqrt(norm_squared);
+}
+
+template<typename T>
+void NK_scale(std::vector<Tensor<T>>& v, double c) {
+  for(auto& tensor: v) {
+    scale(tensor, c);
+  }
+}
+
+template<typename T>
+void NK_accumulate(Scheduler& sch, std::vector<Tensor<T>>& v, const std::vector<Tensor<T>>& w,
+                   double c) {
+  for(size_t i = 0; i < v.size(); ++i) {
+    sch(v[i]() += c * w[i]());
+  }
+  sch.execute();
+}
+
+template<typename T>
+double NK_dotprod(ExecutionContext& ec, const std::vector<Tensor<T>>& v,
+                  const std::vector<Tensor<T>>& w) {
+  double dot_product = 0.0;
+  
+  for(size_t i = 0; i < v.size(); ++i) {
+    Tensor<T> d_s{};
+    Tensor<T>::allocate(&ec, d_s);
+    Scheduler{ec}(d_s() = v[i]() * w[i]()).execute();
+    dot_product += get_scalar(d_s);
+    Tensor<T>::deallocate(d_s);
+  }
+  
+  return dot_product;
+}
+
+template<typename MVPFn, typename T>
+auto arnoldi(ExecutionContext& ec, MVPFn&& mvp, const std::vector<Tensor<T>>& b, int m)
+  -> std::pair<std::vector<std::vector<Tensor<T>>>,
+               Eigen::Matrix<double, Eigen::Dynamic, Eigen::Dynamic, Eigen::RowMajor>> {
+
+  using Matrix = Eigen::Matrix<double, Eigen::Dynamic, Eigen::Dynamic, Eigen::RowMajor>;
+
+  // Q is a matrix if size (size(b), m+1), so using b, I created m+1 columns for Q.
+  std::vector<std::vector<Tensor<T>>> Q;
+  for(int j = 0; j <= m; ++j) {
+    Q.push_back(b);
+    NK_scale(Q.back(), 0.0);
+  }
+
+  Matrix H = Matrix::Zero(m + 1, m);
+
+  auto norm_b = NK_norm(b);
+  // If norm_b is < 1e-14, b is effectively zero
+  if(norm_b < 1e-14) {
+    return {Q, H};
+  }
+
+  auto b0 = b;
+  NK_scale(b0, 1.0 / norm_b);
+  Q[0] = b0;
+
+  for(int k = 0; k < m; ++k) {
+    auto v = mvp(Q[k]);
+
+    for(int j = 0; j <= k; ++j) {
+      H(j, k) = NK_dotprod(ec, Q[j], v); // H[j,k] = dot(Q[:,j], v)
+  //     NK_accumulate(v, Q[j], -H(j, k)); // v .-= H[j,k] .* Q[:,j]
+    }
+
+  //   H(k + 1, k) = NK_norm(v); // H[k+1,k] = norm(v)
+
+  //   // if(H(k + 1, k) < 1e-14) {
+  //   //   break;  TODO:
+  //   // }
+
+  //   NK_scale(v, 1.0 / H(k + 1, k));
+  //   Q[k + 1] = v; // Q[:,k+1] .= v ./ H[k+1,k]
+  }
+
+  return {std::move(Q), std::move(H)};
+}
+
+template<typename MVPFn, typename T>
+std::vector<Tensor<T>> gmres(ExecutionContext& ec, MVPFn&& mvp, const std::vector<Tensor<T>>& b,
+                             int m) {
+  auto [Q, H] = arnoldi(ec, std::forward<MVPFn>(mvp), b, m);
+
+ // TODO: Deallocate Q tensors when done.
+
+  return b; //CHANGE THIS LATER!!!
+}
+
+
+template<typename ResidualFn, typename T>
+void newton_krylov(ExecutionContext& ec, ResidualFn&& F, std::vector<Tensor<T>>& b, double thresh,
+                   int m, int maxiter,
+                   double pert) {
+  auto sch = Scheduler{ec};
+
+  auto& x = b; // x = b
+  
+  if(ec.pg().rank() == 0) {
+    std::cout << "Starting Newton-Krylov iterations with m = " << m << ", maxiter = " << maxiter
+              << ", pert = " << pert << std::endl;
+  }
+
+  for(int iter = 0; iter < maxiter; ++iter) {
+    auto& f_x = F(x);
+
+    auto  f_x_norm = NK_norm(f_x);
+    if(ec.pg().rank() == 0) {
+      std::cout << "NK: " << iter << ", ||F(x)||: " << f_x_norm << std::endl;
+    }
+
+    if(f_x_norm < thresh) {
+      if(ec.pg().rank() == 0) {
+        std::cout << "Converged!" << std::endl;
+      }
+      break;
+    }
+
+    auto Jv = [&](const std::vector<Tensor<T>>& v) {
+      auto v_pert = v;
+      NK_scale(v_pert, pert); // pert .* v
+
+      auto x_pert = x;
+      NK_accumulate(sch, x_pert, v_pert, 1.0); // x + pert .* v
+
+      auto  delta_f_x = F(x_pert);         // F(x + pert*v)
+      NK_accumulate(sch, delta_f_x, f_x, -1.0); // F(x + pert*v) - F(x)
+      NK_scale(delta_f_x, 1.0 / pert);     // ./ pert
+      return delta_f_x;
+    };
+
+    auto neg_f_x = f_x;
+    NK_scale(neg_f_x, -1.0); // -F(x)
+    auto delta_x = gmres(ec, Jv, neg_f_x, m);
+
+    NK_accumulate(sch, x, delta_x, 1.0); // x += delta_x
+
+  }
+}
