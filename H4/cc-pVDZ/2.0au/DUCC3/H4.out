diff --git a/exachem/cc/ccsd/canonical/ccsd_os.cpp b/exachem/cc/ccsd/canonical/ccsd_os.cpp
index ea3acc2..38f9b75 100644
--- a/exachem/cc/ccsd/canonical/ccsd_os.cpp
+++ b/exachem/cc/ccsd/canonical/ccsd_os.cpp
@@ -2634,0 +2635,26 @@ extract_spin_blocks(Scheduler& sch, ChemEnv& chem_env, const Tensor<T>& d_f1,
+template<typename T>
+void arnoldi(ChemEnv& chem_env, ExecutionContext& ec, const TiledIndexSpace& MO, TensorMap<T>& t1,
+               TensorMap<T>& t2, TensorMap<T>& r1, TensorMap<T>& r2, std::vector<Tensor<T>>& d_r1s,
+               std::vector<Tensor<T>>& d_r2s, TensorMap<T>& f, TensorMap<T>& eri){
+
+  Tensor<T> d_e{};
+  Tensor<T>::allocate(&ec, d_e);
+  Scheduler sch{ec};
+  
+  ccsd_os::residuals<T>(sch, chem_env, MO, f, eri, t1, t2, d_e, r1, r2);
+  if(ec.pg().rank() == 0)  std::cout << "Residuals computed" << std::endl;
+}
+
+template<typename T>
+void gmres(ChemEnv& chem_env, ExecutionContext& ec, const TiledIndexSpace& MO, TensorMap<T>& t1,
+               TensorMap<T>& t2, TensorMap<T>& r1, TensorMap<T>& r2, std::vector<Tensor<T>>& d_r1s,
+               std::vector<Tensor<T>>& d_r2s, TensorMap<T>& f, TensorMap<T>& eri){
+
+  Tensor<T> d_e{};
+  Tensor<T>::allocate(&ec, d_e);
+  Scheduler sch{ec};
+  
+  arnoldi(chem_env, ec, MO, t1, t2, r1, r2, d_r1s, d_r2s, f, eri);
+
+}
+
@@ -2721,0 +2748,70 @@ ccsd_v2_driver(ChemEnv& chem_env, ExecutionContext& ec, const TiledIndexSpace& M
+  // *************************************************
+  if(ec.pg().rank() == 0) {std::cout << "STARTING CCSD ITERATIONS - Nick" << std::endl;}
+  
+  double pert = 1e-8;
+
+  //Build MP2 initial guess
+  sch
+    (d_r2(aa,ba,ia,ja) = eri.at("aaaa_vvoo")(aa,ba,ia,ja))
+    (d_r2(aa,bb,ia,jb) = eri.at("abab_vvoo")(aa,bb,ia,jb))
+    (d_r2(ab,bb,ib,jb) = eri.at("bbbb_vvoo")(ab,bb,ib,jb))
+  .execute();
+
+  jacobi(ec, d_r2, d_t2, 0.0, false, p_evl_sorted, n_occ_alpha, n_occ_beta);
+
+  // DEBUG:
+  // print_tensor_all(d_t2);
+  // auto t2_norm = norm(d_t2);
+  // if(ec.pg().rank() == 0){
+  // std::cout << "Norm of t2: " << t2_norm << std::endl;
+  // }
+
+  sch
+  (   t1.at("aa")(aa,ia)            = d_t1(aa,ia))
+  (   t1.at("bb")(ab, ib)           = d_t1(ab,ib))
+  (   t2.at("aaaa")(aa,ba,ia,ja)    = d_t2(aa,ba,ia,ja))
+  (   t2.at("abab")(aa,bb,ia,jb)    = d_t2(aa,bb,ia,jb))
+  (   t2.at("bbbb")(ab,bb,ib,jb)    = d_t2(ab,bb,ib,jb))
+  .execute();
+
+  for(int iter = 0; iter < maxiter; iter++){
+
+    ccsd_os::residuals<T>(sch, chem_env, MO, f, eri, t1, t2, d_e, r1, r2);
+    sch.execute(ec.exhw(), profile);
+    
+    sch
+    (   d_r1(aa,ia)          = r1.at("aa")(aa,ia))
+    (   d_r1(ab,ib)          = r1.at("bb")(ab,ib))
+    (   d_r2(aa,ba,ia,ja)    = r2.at("aaaa")(aa,ba,ia,ja))
+    (   d_r2(aa,bb,ia,jb)    = r2.at("abab")(aa,bb,ia,jb))
+    (   d_r2(ab,bb,ib,jb)    = r2.at("bbbb")(ab,bb,ib,jb))
+    .execute(ec.exhw(), profile);
+    // can get rid of d_r1/2 but would need to rewrite jacobi and something to work on the individual blocks.
+    
+    // DEBUG:
+    auto r1_norm = norm(d_r1);
+    print_tensor_all(d_r1);
+    auto r2_norm = norm(d_r2);
+    print_tensor_all(d_r2);
+    
+    auto total_norm = std::sqrt(r1_norm*r1_norm + r2_norm*r2_norm);
+    
+    if(ec.pg().rank() == 0){
+      std::cout << "Norm of r1, r2 " << r1_norm << ", " << r2_norm << std::endl;
+      std::cout << "Total Norm = " << total_norm << std::endl;
+    }
+
+    if(total_norm < thresh) {
+      std::cout << "Converged at iteration " << iter << std::endl;
+      //Make sure to add the energy expresion here to get the final energy
+      break;
+    }
+
+    gmres(chem_env, ec, MO, t1, t2, r1, r2, d_r1s, d_r2s, f, eri);
+
+  }
+
+
+  
+  // *************************************************
+
@@ -2948,0 +3045,8 @@ template void residuals<double>(Scheduler& sch, ChemEnv& chem_env, const TiledIn
+template void arnoldi<double>(ChemEnv& chem_env, ExecutionContext& ec, const TiledIndexSpace& MO, TensorMap<double>& t1,
+               TensorMap<double>& t2, TensorMap<double>& r1, TensorMap<double>& r2, std::vector<Tensor<double>>& d_r1s,
+               std::vector<Tensor<double>>& d_r2s, TensorMap<double>& f, TensorMap<double>& eri);
+
+template void gmres<double>(ChemEnv& chem_env, ExecutionContext& ec, const TiledIndexSpace& MO, TensorMap<double>& t1,
+               TensorMap<double>& t2, TensorMap<double>& r1, TensorMap<double>& r2, std::vector<Tensor<double>>& d_r1s,
